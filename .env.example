# ===========================================
# WhatsApp AI Outreach — Imperium Finance
# ===========================================
#
# 1. Copy to .env (nebo nastav jako Supabase secrets pro Edge Function — viz níže)
# 2. NIKDY necommituj .env do gitu
#
# ===========================================

# ----- Supabase -----

# Project URL, např. https://zweorumgtocxyocrjtdc.supabase.co
SUPABASE_URL=

# service_role klíč — obchází RLS, používá jen server-side kód
# (Edge Function, scripts/outreach.ts, scripts/stats.ts). NIKDY anon klíč.
SUPABASE_SERVICE_ROLE_KEY=

# ----- Meta WhatsApp Cloud API -----

# System user access token (WhatsApp Business Platform)
# https://developers.facebook.com/apps → tvoje app → WhatsApp → API Setup
META_WA_TOKEN=

# Phone Number ID testovacího čísla (z API Setup)
META_PHONE_NUMBER_ID=

# App Secret — pro HMAC verifikaci X-Hub-Signature-256 na webhooku
# App Dashboard → Settings → Basic → App Secret
META_APP_SECRET=

# Verify token — libovolný řetězec, který zadáš i do Meta webhook konfigurace
# (GET challenge při nastavování webhooku)
META_VERIFY_TOKEN=

# ----- Anthropic (Claude) -----

# https://console.anthropic.com/
ANTHROPIC_API_KEY=
